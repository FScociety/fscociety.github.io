:root,
  ::backdrop {
    --sans-font: -apple-system, "BlinkMacSystemFont", "Avenir Next", "Avenir",
    "Nimbus Sans L", "Roboto", "Noto Sans", "Segoe UI", "Arial", "Helvetica",
    "Helvetica Neue", "sans-serif";
    --mono-font: "Consolas", "Menlo", "Monaco", "Andale Mono", "Ubuntu Mono", "monospace";
    --standard-border-radius: 10px;
    --serif-font: -times-new-roman;

    color-scheme: dark;
    --bg: #212121;
    --accent-bg: #2b2b2b;
    --light-bg: #535353;
    --text: #ffff;
    --text-light: #ababab;
    --border: #898EA4;
    --accent: #ffb300;
    --accent-dark: #ff7b00;
    --accent-text: var(--bg);
    --code: #f06292;
    --preformatted: #ccc;
    --disabled: #111;
  }

html {
  font-family: var(--sans-font);
  scroll-behavior: smooth;
}

body {
  color: var(--text);
  background-color: var(--bg);
  font-size: 1.15rem;
  line-height: 1.5;
  text-align: center;
  margin: 0;
}

.content-container {
  width: 100%;
  max-width: 1000px;
  min-width: 0;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

img {
  border-radius: var(--standard-border-radius);
}

/* Format headers */
h1 {
  font-size: 5rem;
  margin: 0;
  font-weight:bold; 
  font-family: var(--sans-font);
}

h2 {
  text-align: center;
  font-size: 2.6rem;
}

h3 {
  font-size: 2rem;
}

h4 {
  font-size: 1.44rem;
}

h5 {
  font-size: 1.15rem;
}

h6 {
  font-size: 0.96rem;
}

p {
  margin: 1.5rem 0;
  color: var(--text-light);
  font-size: 1.5rem;
}

a {
  color: var(--accent);
}

.selectable {
  transition: scale 0.15s;
}

.selectable:hover {
  scale: 0.99;
}

.row-content {
  /* flex-direction: row-reverse; */
  grid-template-columns: 50% 50%;
  margin: 0px 0px 50px 0px;
  padding: 10px 10px 5px 10px;
  background-color: var(--accent-bg);
  border-radius: var(--standard-border-radius);
}

@media screen and (min-width: 800px) {
  .row-content {
    display: grid;
  }
}
/*# sourceMappingURL=data:application/json;base64, */