header {
  text-align: center;
}

header .header-container {
  z-index: 100;
  width: 100%;
  top: 0;
  position: absolute;
}

header nav {
  display: flex;
  flex-wrap: nowrap;
  /* background-color: var(--accent-bg); */
  background-color: rgba(0, 0, 0, 0);
}

header ul {
  display: flex;
  flex-wrap: nowrap;
  width: 100%;
  list-style-type: none;
  justify-content: center;
}

header nav ul li a {
  display: inline-block;
  color: var(--text-light);
  text-decoration: none;
  background-color: var(--bg);
  border-radius: var(--standard-border-radius);
}

header nav ul li a:hover {
  color: var(--accent);
}

header nav ul li a.active, a.ancestor{
  color: var(--accent);
}

.menu-top-level {
  margin: 10px 0px 5px;
}

.menu-sub-level {
  margin: 5px 0px 10px;
}

.menu-sub-level a {
  margin: 0px 5px;
  padding: 5px 10px;
}

.menu-top-level a {
  margin: 0px 10px;
  padding: 5px 20px;
}
/*# sourceMappingURL=data:application/json;base64, */